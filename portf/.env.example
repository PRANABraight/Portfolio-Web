# Copy this to .env.local and fill in your Sanity project details
# Get these from https://sanity.io/manage after running: npm create sanity@latest

VITE_SANITY_PROJECT_ID=your_project_id_here
VITE_SANITY_DATASET=production

# Server-side only — never use a VITE_ prefix here: VITE_ vars are bundled
# into the public client JS by Vite. These are read via process.env in
# api/send-email.js (Vercel function) and server.js (local dev).
RESEND_API_KEY=your_resend_api_key_here
CONTACT_TO_EMAIL=you@example.com
